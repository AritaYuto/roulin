# =====================================================================
#  Dev / peer profile — roulin-server (native) backed by MinIO.
#  Copy to .env:   cp .example.env .env
#  Then start:     task dev:up         (local MinIO via Docker)
#                  task dev:peer:up    (remote MinIO on a teammate's host)
#
#  roulin-server runs as a native process (Go binary built from source).
#  Docker is used only for spinning up MinIO in dev mode; peer mode does
#  not start any Docker services because the storage backend is already
#  running on someone else's host.
#
#  Server reads each value via its CLI flag first and falls back to the
#  env var below. Optional settings are shown commented out — uncomment
#  only the lines you want to override.
# =====================================================================

# =====================================================================
# Required
# =====================================================================

# S3 URL of the MinIO bucket. The bucket must already exist; in dev mode
# the bundled minio-setup container creates `roulin-dev` automatically.
# In peer mode, ask the peer host to create the bucket via MinIO console
# (:9001) or `mc mb <alias>/<bucket>`.
ROULIN_STORAGE=s3://roulin-test/

# MinIO endpoint reachable from this machine.
#   dev mode (local MinIO via Docker):  http://localhost:9000
#   peer mode (teammate's MinIO):       http://<peer-ip-or-hostname>:9000
ROULIN_STORAGE_ENDPOINT=http://localhost:9000

# Use path-style S3 URLs. Required for MinIO. AWS S3 itself does not need this.
ROULIN_STORAGE_PATH_STYLE=true

# MinIO credentials. Read by the AWS SDK directly, not by roulin-server.
# Defaults below are the dev-MinIO creds — change both on the peer's
# MinIO and here for any shared / persistent setup.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# =====================================================================
# Optional — uncomment to override defaults
# =====================================================================

# Local roulin-server listen port (server default: 8765).
# ROULIN_PORT=8765

# AWS SDK requires a region string even for MinIO; the value is unused
# server-side but the SDK refuses to start without it.
# ROULIN_STORAGE_REGION=us-east-1

# L1 in-memory LRU cap in bytes. 1 GiB default keeps the warm-set hot
# without thrashing.
# ROULIN_CACHE_MEMORY=1073741824

# L2 filesystem cache directory. Empty disables L2 entirely.
# ROULIN_CACHE_DIR=./.cache/roulin

# Log file output directory.
# ROULIN_LOG_DIR=./logs

# =====================================================================
# VCS (incremental build) — optional, leave unset to disable /diff
# =====================================================================

# Absolute path to the engine project's git working tree. The native
# server reads this directly to answer GET /diff?since=<sha>.
ROULIN_VCS_PROJECT_ROOT=/your/path

# Comma-separated git pathspecs that scope /diff queries. Required for
# large repositories: without scoping, `git diff-index` walks every
# tracked file (often >100k entries) and can take minutes per request.
# Set to the directories that actually map into bundles (typically
# Assets and Packages under the engine project root).
ROULIN_VCS_PATHSPECS=client/your-project/Assets,client/your-project/Packages
