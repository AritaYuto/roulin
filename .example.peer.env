# =====================================================================
#  Peer storage profile — local roulin-server + remote MinIO over LAN/VPN.
#  Copy to .env:   cp .example.peer.env .env
#  Then start:     task dev:peer:up
# =====================================================================

# ---- required ----

# S3 URL on the peer's MinIO. The bucket must already exist; create via
# MinIO console (:9001) or `mc mb <alias>/<bucket>` on the peer host.
ROULIN_STORAGE=s3://roulin-test/

# Peer MinIO endpoint reachable from your machine (VPN / LAN IP).
ROULIN_STORAGE_ENDPOINT=http://192.168.1.50:9000

# MinIO credentials. Defaults are minioadmin/minioadmin for dev MinIO; change
# both on the peer's MinIO and here for any shared / persistent setup.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ---- optional ----

# Local roulin-server listen port.
ROULIN_PORT=8765

# AWS SDK requires a region string even for MinIO; the value is unused
# server-side but the SDK refuses to start without it.
ROULIN_STORAGE_REGION=us-east-1

# L1 in-memory LRU cap in bytes. L2 FS cache (under /cache volume) is
# unbounded. 1 GiB default keeps the warm-set hot without thrashing.
ROULIN_CACHE_MEMORY=1073741824
