# =====================================================================
#  Production profile — roulin-server backed by real cloud S3.
#  Copy to .env:   cp .example.prod.env .env
#  Then start:     roulin-server serve   (run the native binary under
#                                         systemd / launchd / etc.)
#
#  Roulin ships a native binary (GitHub Releases) plus a Dockerfile that
#  builds the same binary into a container. Production deployers can pick
#  either and configure entirely through the env vars below; Roulin does
#  not ship a turnkey production compose file.
# =====================================================================

# =====================================================================
# Required
# =====================================================================

# Production S3 URL.
ROULIN_STORAGE=s3://your-bucket/roulin/

# AWS credentials. Prefer IAM role / instance profile on EC2 / ECS / EKS
# (then leave the two below unset and remove them from .env). Static keys
# only when running outside AWS-managed compute.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =====================================================================
# Optional — uncomment to override defaults
# =====================================================================

# Listen port; expose accordingly in your load balancer / ingress.
# ROULIN_PORT=8765

# AWS region of the bucket.
# ROULIN_STORAGE_REGION=us-east-1

# Custom S3 endpoint (only for S3-compatible providers; leave unset for real AWS S3).
# ROULIN_STORAGE_ENDPOINT=

# Use path-style URLs. Required for some S3-compatible providers (MinIO etc.);
# AWS S3 itself does not need this.
# ROULIN_STORAGE_PATH_STYLE=false

# L1 in-memory LRU cap in bytes. Tune for the host's RAM headroom; L2
# filesystem cache is unbounded.
# ROULIN_CACHE_MEMORY=1073741824

# L2 filesystem cache directory. Empty disables L2.
# ROULIN_CACHE_DIR=/var/cache/roulin

# Log file output directory.
# ROULIN_LOG_DIR=/var/log/roulin

# =====================================================================
# VCS — typically unset in production
# =====================================================================
# Production deployments usually leave VCS-related vars unset because
# the /diff endpoint is a developer-time feature, not a CDN-serving one.

# ROULIN_VCS_PROJECT_ROOT=
# ROULIN_VCS_PATHSPECS=
