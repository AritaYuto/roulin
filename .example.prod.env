# =====================================================================
#  Production profile — roulin-server backed by real cloud S3.
#  Copy to .env:   cp .example.prod.env .env
#  Then start:     docker compose -f compose.prod.yml up -d
# =====================================================================

# ---- required ----

# Production S3 URL.
ROULIN_STORAGE=s3://your-bucket/roulin/

# AWS credentials. Prefer IAM role / instance profile on EC2 / ECS / EKS
# (then leave the two below unset and remove them from .env). Static keys
# only when running outside AWS-managed compute.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- optional ----

# Listen port; expose accordingly in your load balancer / ingress.
ROULIN_PORT=8765

# AWS region of the bucket.
ROULIN_STORAGE_REGION=us-east-1

# L1 in-memory LRU cap in bytes. Tune for the host's RAM headroom; L2 FS
# cache on the `roulin-cache` volume is unbounded.
ROULIN_CACHE_MEMORY=1073741824
